PORT=3001
JWT_SECRET="change-this-in-production"

# Local (SQLite)
# DATABASE_URL="file:./dev.db"

# Supabase — use session pooler (port 5432) for migrations and runtime
# Transaction pooler (port 6543) does NOT support DDL operations
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"
